# pi-gen config for the Airlock image.
# Referenced by image/pi-gen/build.sh.

IMG_NAME="airlock"
RELEASE="trixie"
DEPLOY_COMPRESSION="xz"

# arm64 for Pi 4 / Pi 5.
PI_GEN_RELEASE="Airlock $(date +%Y.%m.%d)"
ARCH="arm64"

# Locale / keyboard / timezone: sensible neutral defaults.
LOCALE_DEFAULT="en_US.UTF-8"
KEYBOARD_KEYMAP="us"
KEYBOARD_LAYOUT="English (US)"
TIMEZONE_DEFAULT="Etc/UTC"

# Networking / identity.
TARGET_HOSTNAME="airlock"

# Default local user is airlock/airlock.
#
# WEAK DEFAULT — users MUST change it on first boot with `passwd`,
# or set their own credentials via Pi Imager's OS customization dialog
# (which rewrites firstrun.sh on the boot partition before flashing).
# SSH is enabled and accepts passwords; we can't ship a baked-in public
# key that would work for everyone, and disabling SSH entirely would
# lock out users who don't run Pi Imager.
FIRST_USER_NAME="airlock"
FIRST_USER_PASS="airlock"
DISABLE_FIRST_BOOT_USER_RENAME=1
ENABLE_SSH=1

# Only build lite + our stage. No desktop.
STAGE_LIST="stage0 stage1 stage2 stage-airlock"
