<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<!--
  Avahi advertisements for airlock.

  The `_device-info._tcp` record with `model=MacPro7,1` tells macOS
  Finder to render this host with the Mac Pro tower icon in the Network
  sidebar rather than the generic computer/monitor icon. The
  `@ECOLOR=226,226,224` suffix is Apple's colour hint (light silver) —
  the same trick TrueNAS uses. Port 0: this record only carries
  metadata via the TXT payload.

  For Finder to pick up our model, Samba's own mDNS publisher must be
  disabled (`multicast dns register = no` in smb.conf). Otherwise Samba
  ships its own _device-info record with model=MacSamba and shadows
  ours.
-->
<service-group>
  <name replace-wildcards="yes">Airlock on %h</name>
  <service>
    <type>_smb._tcp</type>
    <port>445</port>
  </service>
  <service>
    <type>_http._tcp</type>
    <port>80</port>
  </service>
  <service>
    <type>_device-info._tcp</type>
    <port>0</port>
    <txt-record>model=MacPro7,1@ECOLOR=226,226,224</txt-record>
  </service>
</service-group>
